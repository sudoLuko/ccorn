<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened runtime blocks outgoing AppleEvents without this; CCorn
	     automates Terminal for "Open in Terminal". The App Sandbox stays OFF
	     (deliberately absent here): CCorn must spawn tmux/claude/ps/lsof and
	     watch arbitrary directories with FSEvents. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
</dict>
</plist>
