# Xcode derived data / build output (regenerated by xcodebuild)
build/
DerivedData/

# macOS
.DS_Store

# Xcode user state (regenerated; not part of the shared project)
*.xcuserstate
**/xcuserdata/

# XcodeGen-generated project (regenerate with `xcodegen generate`)
CCorn.xcodeproj/

# Info.plist is generated by xcodegen from project.yml
Sources/Info.plist
build-release/

# Local Claude Code state (settings.local.json, worktrees) — never commit
.claude/

# Internal research / working notes — kept out of the public repo
docs/research/
docs/ANIMATION_AUDIT_VERIFICATION.md

# Design-process artifacts (iteration screenshots, source files) — the shipped
# assets live in Sources/Assets.xcassets and docs/images; these are working history
docs/screenshots/
design-assets/corn-glyph/
design-assets/status-color-swatches.png
design-assets/status-colors-before-after.png
# App-icon source renders (1024px masters + discarded alternatives); the
# shipped icon lives in Sources/Assets.xcassets, the vector source is the
# committed .svg. Keep ICON_CREDITS.md tracked for the CC BY-SA obligation.
design-assets/app-icon/*-1024.png
